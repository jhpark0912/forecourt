# Forecourt 환경변수 템플릿
# 사용법: 이 파일을 복사해 .env 로 만들고 실제 값을 채운다.  cp .env.example .env
# .env 는 .gitignore 처리됨 — 실제 키를 여기(.example)에 적지 말 것.

# ── 국토부 실거래가 API (현재 사용) ──────────────────────────────
# data.go.kr 발급 인증키. URL에 그대로 붙일 Encoding 인증키 사용.
# 호출 시 User-Agent 헤더 필수(없으면 게이트웨이가 Request Blocked 400).
MOLIT_SERVICE_KEY=

# ── Supabase Postgres (코드 착수 시 사용 — DESIGN.md §6.3) ────────
# Direct(5432) 연결 문자열. 상주 Spring 백엔드는 Direct 사용.
# SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=

# ── 카카오 지도/주소 API (등록 흐름 구현 시 — DESIGN.md §8) ───────
# KAKAO_REST_API_KEY=
# KAKAO_JS_KEY=
